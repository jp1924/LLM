{
    // IntelliSenseые╝ ьВмьЪйэХШьЧм ъ░АыКеэХЬ эК╣ьД▒ьЧР ыМАэХ┤ ьХМьХДы│┤ьД╕ьЪФ.
    // ъ╕░ьб┤ эК╣ьД▒ьЧР ыМАэХЬ ьДдыкЕьЭД ы│┤ыадый┤ ъ░АыжмэВ╡ыЛИыЛд.
    // ьЮРьД╕эХЬ ыВ┤ьЪйьЭД ы│┤ыадый┤ https://go.microsoft.com/fwlink/?linkid=830387ьЭД(ые╝) ы░йым╕эХШьД╕ьЪФ.
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
        },
        {
            "name": "VeRL debug attach",
            "type": "debugpy",
            "request": "attach",
            "justMyCode": false,
            "connect": {
                "host": "172.23.0.2",
                "port": 40669
            }
        },
        {
            "name": "VeRL debug",
            "type": "debugpy",
            "request": "launch",
            "module": "recipe.dapo.main_dapo",
            "console": "integratedTerminal",
            "cwd": "/root/verl",
            "justMyCode": false,
            "env": {
                "HYDRA_FULL_ERROR": "1"
            },
            "args": [
                "--config-path=/root/verl/config",
                "--config-name=grpo_gemma3_dapo",
                "trainer.experiment_name=debug",
            ],
        },
        {
            "name": "run sft debug",
            "type": "debugpy",
            "request": "launch",
            "module": "accelerate.commands.launch",
            "console": "integratedTerminal",
            "cwd": "/root/workspace/src/sft",
            "justMyCode": false,
            // "env": {
            //     "NCCL_DEBUG": "INFO"
            // },
            "args": [
                "--config_file=/root/workspace/config/accelerator/zero3.yaml",
                "/root/workspace/src/sft/main.py",
                "--config",
                "/root/workspace/run_scripts/sft.yaml"
            ],
        },
        {
            "name": "debug: ds sft main.py",
            "type": "debugpy",
            "request": "launch",
            "module": "deepspeed.launcher.runner",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "TORCH_DISTRIBUTED_DEBUG": "DETAIL",
                "TORCH_USE_CUDA_DSA": "1",
                "CUDA_LAUNCH_BLOCKING": "1",
                "TORCHDYNAMO_DISABLE": "1",
            },
            "args": [
                "--include=localhost:2,3",
                "/root/workspace/src/main.py",
                "--output_dir=/root/output_dir/gemma-2-9b/national-corpus/sft",
                "--cache_dir=/root/.cache/.[gemma-2-9b]preprocess/CorpusForLLMNationalRecordsAndArchives",
                "--run_name=debug",
                "--model_name_or_path=/root/output_dir/gemma-2-9b/national-corpus/pretrained_model",
                "--preprocessing_batched=true",
                "--preprocessing_num_workers=20",
                "--preprocessing_batch_size=1000",
                "--data_preprocessor_type=sft", // эФДыбЬьД╕ьДЬ эГАьЮЕьЭД pretrainьЬ╝ыбЬ ы░Фъ┐И.
                "--dataset_repo_ls",
                "jp1924/CorpusForLLMNationalRecordsAndArchives",
                "--data_name_map={\"jp1924/CorpusForLLMNationalRecordsAndArchives\": \"SFT\"}",
                "--train_dataset_prefix=train",
                "--per_device_train_batch_size=2",
                "--gradient_accumulation_steps=1",
                "--per_device_eval_batch_size=1",
                "--eval_accumulation_steps=1",
                "--num_train_epochs=1",
                "--seed=42",
                "--do_train=true",
                "--do_eval=false",
                "--do_predict=false",
                "--report_to=none",
                "--learning_rate=2e-5",
                "--lr_scheduler_type=cosine",
                "--warmup_ratio=0.03",
                "--weight_decay=0",
                "--eval_strategy=no", //
                "--eval_steps=1", //
                "--save_strategy=no", //
                "--save_steps=1", //
                "--logging_strategy=steps",
                "--logging_steps=1",
                "--bf16=true",
                "--tf32=true",
                "--data_max_length=2048",
                "--ddp_timeout=18000000",
                "--profiling=false",
                "--do_data_main_process_first=true",
                "--use_liger_kernel=true",
                "--torch_compile=true",
                "--gradient_checkpointing=true",
                "--gradient_checkpointing_kwargs={\"use_reentrant\": false}",
                "--padding_side=right",
                "--dataloader_prefetch_factor=1",
                "--dataloader_num_workers=1",
                "--attn_implementation=flash_attention_2",
                "--remove_unused_columns=false",
                "--do_packing=true",
                "--packing_max_elem=20",
                "--packing_shuffle=true",
                "--group_by_length=false",
                "--response_template=[106, 6176, 18145, 235292]",
                "--instruction_template=[106, 6176, 4926, 235292]",
                "--torch_empty_cache_steps=100",
                "--optim=adafactor",
                "--deepspeed=/root/workspace/config/ZeRO_3_act_check.json",
            ]
        },
        {
            "name": "debug: pretrain main.py",
            "type": "debugpy",
            "request": "launch",
            "module": "deepspeed.launcher.runner",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "TORCH_DISTRIBUTED_DEBUG": "DETAIL",
                "TORCH_USE_CUDA_DSA": "1",
                "CUDA_LAUNCH_BLOCKING": "1",
                "TORCHDYNAMO_DISABLE": "1",
            },
            "args": [
                "--num_gpus=4",
                "/root/workspace/src/main.py",
                "--output_dir=/root/output_dir/google/gemma-2-9b/pretrain",
                "--cache_dir=/root/.cache/.[google/gemma-2-9b]preprocess/CorpusForLLMNationalRecordsAndArchives",
                "--run_name=debug",
                "--model_name_or_path=google/gemma-2-9b",
                "--preprocessing_batched=true",
                "--preprocessing_num_workers=20",
                "--preprocessing_batch_size=1000",
                "--data_preprocessor_type=pretrain", // эФДыбЬьД╕ьДЬ эГАьЮЕьЭД pretrainьЬ╝ыбЬ ы░Фъ┐И.
                "--dataset_repo_ls",
                "jp1924/CorpusForLLMNationalRecordsAndArchives",
                "--data_name_map={\"jp1924/CorpusForLLMNationalRecordsAndArchives\": \"CORPUS\"}",
                "--train_dataset_prefix=train",
                "--per_device_train_batch_size=40",
                "--gradient_accumulation_steps=1",
                "--per_device_eval_batch_size=10",
                "--eval_accumulation_steps=1",
                "--num_train_epochs=1",
                "--seed=42",
                "--do_train=true",
                "--do_eval=false",
                "--do_predict=false",
                "--report_to=none",
                "--learning_rate=2e-5",
                "--lr_scheduler_type=cosine",
                "--warmup_ratio=0.03",
                "--weight_decay=0",
                "--eval_strategy=no", //
                "--eval_steps=1", //
                "--save_strategy=no", //
                "--save_steps=1", //
                "--logging_strategy=steps",
                "--logging_steps=1",
                "--bf16=true",
                "--tf32=true",
                "--data_max_length=2048",
                "--ddp_timeout=18000000",
                "--profiling=false",
                "--do_data_main_process_first=true",
                "--use_liger_kernel=true",
                "--torch_compile=true",
                "--gradient_checkpointing=true",
                "--gradient_checkpointing_kwargs={\"use_reentrant\": false}",
                "--padding_side=right",
                "--dataloader_prefetch_factor=5",
                "--dataloader_num_workers=4",
                "--attn_implementation=flash_attention_2",
                "--remove_unused_columns=true",
                "--do_packing=false",
                "--packing_max_elem=20",
                "--packing_shuffle=true",
                "--group_by_length=false",
                "--torch_empty_cache_steps=100",
                "--deepspeed=/root/workspace/config/ZeRO_3_act_check.json",
            ]
        },
    ]
}